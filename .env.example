# ──────────────────────────────────────────────────────────────────────────────
# PageIndex Vectorless RAG — environment configuration template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The demo works with ANY OpenAI-compatible LLM endpoint — local or cloud.
# ──────────────────────────────────────────────────────────────────────────────


# ── LLM Endpoint ──────────────────────────────────────────────────────────────
#
# Option A: Local server (LM Studio, Ollama, vLLM, LiteLLM proxy, Jan, …)
#
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=llama-3.1-8b-instruct
#
# Option B: OpenAI cloud
#
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-2024-11-20
#
# Option C: Azure OpenAI
#
# LLM_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT
# LLM_API_KEY=YOUR_AZURE_KEY
# LLM_MODEL=azure/gpt-4o
#
# Option D: Anthropic (via LiteLLM prefix)
#
# LLM_BASE_URL=https://api.anthropic.com
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=anthropic/claude-sonnet-4-6
#
# Option E: Ollama (local)
#
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1


# ── Optional: separate model for the tree-search step ─────────────────────────
# Defaults to LLM_MODEL when not set.  Use a smaller/faster model here
# if you want to reduce cost on the navigation step.
#
# RETRIEVE_MODEL=llama-3.1-8b-instruct


# ── PageIndex tuning ──────────────────────────────────────────────────────────

# Leading pages to scan for a table of contents
TOC_CHECK_PAGES=20

# Max PDF pages collapsed into a single index node
MAX_PAGES_PER_NODE=10

# Token ceiling per index node
MAX_TOKENS_PER_NODE=20000


# ── Paths ──────────────────────────────────────────────────────────────────────
RESULTS_DIR=results
