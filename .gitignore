# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
*.key
*.pem

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST
pip-wheel-metadata/
share/python-wheels/
lib/
lib64/
parts/
sdist/
var/
wheels/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.virtualenvs/

# ── Test & coverage ───────────────────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.cache/
nosetests.xml
coverage.xml
*.cover

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Project data — keep structure, ignore content ────────────────────────────
# data/ holds user documents; only the sample doc is tracked
data/*
!data/.gitkeep
!data/sample_report.md
results/*
!results/.gitkeep
demo/*.gif
demo/preview_*.png
*.pdf
